# GoalFlow API Environment Variables Configuration
# Copy this to .env and adjust values for local development

# Database Settings
# For local setup, use standard Postgres defaults or the docker-compose service name
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goalflow

# JWT Authentication Config
JWT_SECRET=goalflow_super_secret_key_123!

# AI Coach Engine Configuration
# Provide an Anthropic API Key to connect GoalFlow to Claude 3.5 Sonnet directly
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Microsoft Teams Webhook Settings
# Provide your channel incoming webhook URL to receive notifications on manager approval
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/your-teams-channel-webhook-url

# Pusher Channels Config (For real-time WebSockets completion metrics)
PUSHER_APP_ID=123456
PUSHER_KEY=goalflow_pusher_key
PUSHER_SECRET=goalflow_pusher_secret
PUSHER_CLUSTER=ap2
